<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HakozunaBenchLab.App.MainWindow"
        Width="1100"
        Height="720"
        Title="Hakozuna Bench Lab">
  <TabControl Margin="20">
    <TabItem Header="Run">
      <Grid RowDefinitions="Auto,*,Auto" Margin="8,18,8,8">
        <StackPanel Spacing="6">
          <TextBlock FontSize="30" FontWeight="Bold" Foreground="#18212B">Hakozuna Bench Lab</TextBlock>
          <TextBlock Foreground="#596773">Measure speed and memory together.</TextBlock>
        </StackPanel>
        <Grid Grid.Row="1" ColumnDefinitions="260,*" ColumnSpacing="24" Margin="0,28,0,24">
          <Border Background="#F1E9DC" CornerRadius="14" Padding="18">
            <StackPanel Spacing="14">
              <TextBlock Text="RUN SETUP" FontWeight="Bold" Foreground="#8A4B2A" />
              <TextBlock Text="Allocator" />
              <ComboBox x:Name="AllocatorComboBox" SelectedIndex="0">
                <ComboBoxItem Content="HZ8" />
                <ComboBoxItem Content="system" />
                <ComboBoxItem Content="mimalloc" />
                <ComboBoxItem Content="tcmalloc" />
              </ComboBox>
              <TextBlock Text="Workload" />
              <ComboBox x:Name="WorkloadComboBox" SelectedIndex="0">
                <ComboBoxItem Content="Local Mixed" />
                <ComboBoxItem Content="Remote 90" />
                <ComboBoxItem Content="Medium Mixed" />
                <ComboBoxItem Content="RSS Turnover" />
              </ComboBox>
              <CheckBox x:Name="VerifiedModeCheckBox" Content="Verified mode (provider packs next)" IsChecked="False" IsEnabled="False" />
              <Button x:Name="RunButton" Content="Run benchmark" Click="RunBenchmarkClick" HorizontalContentAlignment="Center" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Background="#FBF8F2" BorderBrush="#D8CDBD" BorderThickness="1" CornerRadius="14" Padding="24">
            <StackPanel Spacing="18">
              <TextBlock Text="RESULT OVERVIEW" FontWeight="Bold" Foreground="#8A4B2A" />
              <TextBlock x:Name="RunStatusText" Text="No verified run yet" FontSize="24" Foreground="#18212B" />
              <TextBlock Text="Throughput and RSS charts will appear here after the isolated runner completes." TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Border Background="#E4EFEA" CornerRadius="10" Padding="14"><StackPanel><TextBlock Text="OPS/S"/><TextBlock x:Name="OpsValueText" Text="--" FontSize="24"/></StackPanel></Border>
                <Border Grid.Column="1" Background="#E8EDF4" CornerRadius="10" Padding="14"><StackPanel><TextBlock Text="PEAK RSS"/><TextBlock x:Name="PeakRssValueText" Text="--" FontSize="24"/></StackPanel></Border>
                <Border Grid.Column="2" Background="#F4E4D9" CornerRadius="10" Padding="14"><StackPanel><TextBlock Text="POST RSS"/><TextBlock x:Name="PostRssValueText" Text="--" FontSize="24"/></StackPanel></Border>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>
        <TextBlock Grid.Row="2" Text="Preview is directional. Verified results retain raw output, hashes, and run conditions." Foreground="#596773" />
      </Grid>
    </TabItem>
    <TabItem Header="Providers">
      <ScrollViewer>
        <StackPanel Margin="8,22" Spacing="18" MaxWidth="940" HorizontalAlignment="Stretch">
          <StackPanel Spacing="6">
            <TextBlock Text="Allocator Providers" FontSize="30" FontWeight="Bold" Foreground="#18212B" />
            <TextBlock Text="Allocator binaries stay outside the GUI process. Packs are verified before installation and versions are kept side by side." Foreground="#596773" TextWrapping="Wrap" />
          </StackPanel>
          <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <Border Background="#E4EFEA" CornerRadius="14" Padding="18">
              <StackPanel Spacing="7">
                <TextBlock Text="system" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Bundled provider" Foreground="#39705B" />
                <TextBlock Text="Uses the operating system allocator." TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#F1E9DC" CornerRadius="14" Padding="18">
              <StackPanel Spacing="7">
                <TextBlock Text="HZ8" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Bundled provider" Foreground="#8A4B2A" />
                <TextBlock Text="The balanced low-RSS Hakozuna provider." TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </Grid>
          <Border Background="#FBF8F2" BorderBrush="#D8CDBD" BorderThickness="1" CornerRadius="14" Padding="20">
            <StackPanel Spacing="12">
              <TextBlock Text="INSTALL A PROVIDER PACK" FontWeight="Bold" Foreground="#8A4B2A" />
              <TextBlock Text="Import mimalloc, tcmalloc, or a custom .hbl-provider.zip. No package is downloaded silently." TextWrapping="Wrap" />
              <Button Content="Choose provider pack..." Click="ImportProviderClick" HorizontalAlignment="Left" Padding="18,9" />
              <TextBlock x:Name="ProviderStatusText" Text="No pack selected." Foreground="#596773" TextWrapping="Wrap" />
              <TextBlock x:Name="ProviderRootText" FontSize="12" Foreground="#7A8790" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>
  </TabControl>
</Window>
